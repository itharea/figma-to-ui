{
  "name": "figma-to-ui",
  "version": "1.0.0",
  "description": "Decode binary Figma .fig export files locally — no Figma account, plugin, or REST API. Extract design tokens, layouts, copy, components, SVG vectors, and image/video assets for 1:1 UI implementation.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "figma",
    "fig",
    "design-tokens",
    "svg",
    "ui",
    "fig-kiwi",
    "design-to-code"
  ],
  "scripts": {
    "parse": "node scripts/parse.mts",
    "tree": "node scripts/tree.mts",
    "find": "node scripts/find.mts",
    "build-ir": "node scripts/build-ir.mts",
    "theme-gen": "node scripts/theme-gen.mts",
    "codegen": "node scripts/codegen.mts",
    "raw": "node scripts/raw.mts",
    "export-svg": "node scripts/export-svg.mts",
    "selftest": "node scripts/selftest.mts",
    "test": "node scripts/selftest.mts"
  },
  "engines": {
    "node": ">=22.18"
  },
  "dependencies": {
    "kiwi-schema": "^0.5.0"
  }
}
