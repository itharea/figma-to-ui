{
  "name": "figma-to-ui",
  "version": "1.0.0",
  "description": "Decode binary Figma .fig export files locally — no Figma account, plugin, or REST API. Extract design tokens, layouts, copy, components, SVG vectors, and image/video assets for 1:1 UI implementation.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "figma",
    "fig",
    "design-tokens",
    "svg",
    "ui",
    "fig-kiwi",
    "design-to-code"
  ],
  "scripts": {
    "parse": "node scripts/cli/parse.mts",
    "tree": "node scripts/cli/tree.mts",
    "find": "node scripts/cli/find.mts",
    "build-ir": "node scripts/cli/build-ir.mts",
    "theme-gen": "node scripts/cli/theme-gen.mts",
    "codegen": "node scripts/cli/codegen.mts",
    "raw": "node scripts/cli/raw.mts",
    "export-svg": "node scripts/cli/export-svg.mts",
    "selftest": "node scripts/selftest.mts",
    "test": "node scripts/selftest.mts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=22.18"
  },
  "dependencies": {
    "kiwi-schema": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3"
  }
}
